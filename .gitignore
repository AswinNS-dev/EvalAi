# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Environment variables (CRITICAL)
.env

# Virtual environments
venv/
.venv/
env/
ENV/

# Data and uploads (keep the folders but ignore their contents)
data/uploads/*
!data/uploads/.gitkeep
data/indexes/*
!data/indexes/.gitkeep

# IDEs and Editors
.vscode/
.idea/
*.swp
*.swo

# OS generated files
.DS_Store
Thumbs.db
