# ── Groq LLM ──────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_...
GROQ_API_KEY_SLIDE=gsk_...
GROQ_API_KEY_REPO=gsk_...
GROQ_API_KEY_IMPACT=gsk_...
GROQ_API_KEY_TECH=gsk_...
GROQ_API_KEY_CLAIM=gsk_...
GROQ_API_KEY_CHIEF=gsk_...

# ── HuggingFace (for BAAI/bge-base-en-v1.5 embeddings) ───────────────────────
HUGGINGFACE_API_TOKEN=hf_...

# ── GitHub (PyGithub repo analysis) ───────────────────────────────────────────
GITHUB_TOKEN=ghp_...

# ── Snowflake (audit log + results persistence) ────────────────────────────────
SNOWFLAKE_ACCOUNT=xyz12345.ap-south-1.aws
SNOWFLAKE_USER=...
SNOWFLAKE_PASSWORD=...
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=EVALAI_DB
SNOWFLAKE_SCHEMA=PUBLIC

# ── Twilio (SMS/WhatsApp notifications) ───────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1415...

# ── App Settings ──────────────────────────────────────────────────────────────
# Leave SNOWFLAKE_ACCOUNT blank to fall back to SQLite (data/evalai.db)
SQLITE_FALLBACK_PATH=data/evalai.db

# Frontend URL (used in Twilio notification links)
FRONTEND_URL=http://localhost:3000
